---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryColors: Record<string, string> = {
  'computer-science': 'from-blue-500 to-cyan-500',
  'space-technology': 'from-violet-500 to-purple-500',
  'artificial-intelligence': 'from-primary-500 to-accent-500',
  'quantum-physics': 'from-rose-500 to-orange-500',
  'nature': 'from-green-500 to-emerald-500',
};

const categoryIcons: Record<string, string> = {
  'computer-science': '💻',
  'space-technology': '🚀',
  'artificial-intelligence': '🤖',
  'quantum-physics': '⚛️',
  'nature': '🌿',
};

const gradient = categoryColors[post.data.category] || 'from-primary-500 to-accent-500';
const icon = categoryIcons[post.data.category] || '📝';
const formattedDate = post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Back link -->
    <a href="/tech-blog/blog/" class="inline-flex items-center gap-1 text-dark-300 hover:text-primary-400 text-sm mb-8 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to articles
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-gradient-to-r ${gradient} text-white`}>
          <span>{icon}</span>
          {post.data.category.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}
        </span>
        <time class="text-dark-300 text-sm">{formattedDate}</time>
      </div>

      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
        {post.data.title}
      </h1>

      <p class="text-dark-200 text-lg leading-relaxed">
        {post.data.description}
      </p>

      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="px-2.5 py-0.5 rounded-md bg-dark-600 text-dark-200 text-xs">#{tag}</span>
          ))}
        </div>
      )}

      <div class={`h-px bg-gradient-to-r ${gradient} mt-8 opacity-30`}></div>

      {post.data.image && (
        <div class="mt-8 rounded-2xl overflow-hidden border border-dark-500/30">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-64 sm:h-80 md:h-96 object-cover"
          />
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="prose max-w-none">
      <Content />
    </div>
  </article>

  <!-- Interactive Python Runner (Pyodide) -->
  <style>
    .code-runner-wrapper {
      position: relative;
    }
    .code-runner-wrapper pre {
      margin-bottom: 0 !important;
      border-bottom-left-radius: 0 !important;
      border-bottom-right-radius: 0 !important;
    }
    .code-toolbar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
      background: #1e1f22;
      border: 1px solid #373a40;
      border-top: none;
      border-bottom-left-radius: 0.5rem;
      border-bottom-right-radius: 0.5rem;
    }
    .run-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.375rem 0.875rem;
      font-size: 0.8125rem;
      font-weight: 600;
      font-family: 'Inter', system-ui, sans-serif;
      color: #fff;
      background: linear-gradient(135deg, #20c997, #12b886);
      border: none;
      border-radius: 0.375rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .run-btn:hover {
      background: linear-gradient(135deg, #38d9a9, #20c997);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(32, 201, 151, 0.3);
    }
    .run-btn:active {
      transform: translateY(0);
    }
    .run-btn.loading {
      opacity: 0.7;
      cursor: wait;
    }
    .run-btn svg {
      width: 14px;
      height: 14px;
    }
    .reset-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.375rem 0.625rem;
      font-size: 0.75rem;
      font-weight: 500;
      font-family: 'Inter', system-ui, sans-serif;
      color: #909296;
      background: transparent;
      border: 1px solid #373a40;
      border-radius: 0.375rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .reset-btn:hover {
      color: #c1c2c5;
      border-color: #5c5f66;
    }
    .toolbar-label {
      margin-left: auto;
      font-size: 0.6875rem;
      font-family: 'JetBrains Mono', monospace;
      color: #5c5f66;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .code-output {
      margin-top: 0;
      margin-bottom: 1.5rem;
      padding: 0.75rem 1rem;
      background: #0d0e10;
      border: 1px solid #373a40;
      border-top: 1px dashed #373a40;
      border-bottom-left-radius: 0.5rem;
      border-bottom-right-radius: 0.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8125rem;
      line-height: 1.6;
      color: #63e6be;
      white-space: pre-wrap;
      word-break: break-word;
      max-height: 300px;
      overflow-y: auto;
    }
    .code-output.has-output {
      display: block;
    }
    .code-output .output-label {
      display: block;
      font-size: 0.625rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #5c5f66;
      margin-bottom: 0.375rem;
    }
    .code-output .error-text {
      color: #ff6b6b;
    }
    .pyodide-loading-banner {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.75rem;
      color: #ffd43b;
      background: rgba(255, 212, 59, 0.08);
      border: 1px solid rgba(255, 212, 59, 0.15);
      border-radius: 0.375rem;
      margin-bottom: 0.5rem;
      animation: pulse-glow 2s ease-in-out infinite;
    }
    @keyframes pulse-glow {
      0%, 100% { opacity: 0.8; }
      50% { opacity: 1; }
    }
    .spinner {
      width: 14px;
      height: 14px;
      border: 2px solid rgba(255, 255, 255, 0.2);
      border-top-color: #20c997;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .code-toolbar .run-btn .play-icon { display: inline; }
    .code-toolbar .run-btn .spin-icon { display: none; }
    .code-toolbar .run-btn.loading .play-icon { display: none; }
    .code-toolbar .run-btn.loading .spin-icon { display: inline; }
    /* Make code editable when runner is attached */
    .code-runner-wrapper pre code {
      outline: none;
    }
    .code-runner-wrapper pre code:focus {
      outline: 1px solid rgba(92, 124, 250, 0.3);
      outline-offset: -1px;
      border-radius: 4px;
    }
    .edit-hint {
      font-size: 0.6875rem;
      color: #5c5f66;
      font-family: 'Inter', system-ui, sans-serif;
    }
  </style>

  <script>
    let pyodideInstance: any = null;
    let pyodideLoading = false;
    const loadingCallbacks: (() => void)[] = [];

    async function loadPyodideRuntime() {
      if (pyodideInstance) return pyodideInstance;
      if (pyodideLoading) {
        return new Promise<any>((resolve) => {
          loadingCallbacks.push(() => resolve(pyodideInstance));
        });
      }

      pyodideLoading = true;

      // Load the Pyodide script
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/pyodide/v0.25.1/full/pyodide.js';
      document.head.appendChild(script);

      await new Promise<void>((resolve, reject) => {
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('Failed to load Pyodide'));
      });

      // @ts-ignore - loadPyodide is loaded via script tag
      pyodideInstance = await (window as any).loadPyodide({
        indexURL: 'https://cdn.jsdelivr.net/pyodide/v0.25.1/full/',
      });

      pyodideLoading = false;
      loadingCallbacks.forEach((cb) => cb());
      loadingCallbacks.length = 0;

      return pyodideInstance;
    }

    function initCodeRunners() {
      const codeBlocks = document.querySelectorAll('.prose pre > code.language-python');

      codeBlocks.forEach((codeEl) => {
        const pre = codeEl.parentElement;
        if (!pre || pre.closest('.code-runner-wrapper')) return;

        const originalCode = (codeEl as HTMLElement).innerText;

        // Wrap pre in a container
        const wrapper = document.createElement('div');
        wrapper.className = 'code-runner-wrapper';
        pre.parentNode!.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        // Make code editable
        (codeEl as HTMLElement).contentEditable = 'true';
        (codeEl as HTMLElement).spellcheck = false;

        // Toolbar
        const toolbar = document.createElement('div');
        toolbar.className = 'code-toolbar';

        const runBtn = document.createElement('button');
        runBtn.className = 'run-btn';
        runBtn.innerHTML = `
          <span class="play-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
          <span class="spin-icon"><span class="spinner"></span></span>
          Run
        `;

        const resetBtn = document.createElement('button');
        resetBtn.className = 'reset-btn';
        resetBtn.textContent = '↺ Reset';

        const editHint = document.createElement('span');
        editHint.className = 'edit-hint';
        editHint.textContent = '✎ editable';

        const label = document.createElement('span');
        label.className = 'toolbar-label';
        label.textContent = 'Python';

        toolbar.appendChild(runBtn);
        toolbar.appendChild(resetBtn);
        toolbar.appendChild(editHint);
        toolbar.appendChild(label);
        wrapper.appendChild(toolbar);

        // Output area (hidden initially)
        const outputEl = document.createElement('div');
        outputEl.className = 'code-output';
        outputEl.style.display = 'none';

        // Reset handler
        resetBtn.addEventListener('click', () => {
          (codeEl as HTMLElement).innerText = originalCode;
          outputEl.style.display = 'none';
          outputEl.innerHTML = '';
          // Move toolbar back to right after pre
          wrapper.insertBefore(toolbar, outputEl);
        });

        // Run handler
        runBtn.addEventListener('click', async () => {
          const code = (codeEl as HTMLElement).innerText;
          runBtn.classList.add('loading');
          runBtn.disabled = true;

          // Show loading banner on first load
          let banner: HTMLElement | null = null;
          if (!pyodideInstance) {
            banner = document.createElement('div');
            banner.className = 'pyodide-loading-banner';
            banner.innerHTML = '<span class="spinner"></span> Loading Python runtime (first run only, ~10 MB)...';
            wrapper.insertBefore(banner, toolbar.nextSibling);
          }

          try {
            const pyodide = await loadPyodideRuntime();
            if (banner) banner.remove();

            // Capture stdout and stderr
            pyodide.runPython(`
import sys, io
__stdout_capture = io.StringIO()
__stderr_capture = io.StringIO()
sys.stdout = __stdout_capture
sys.stderr = __stderr_capture
`);

            let result: any;
            let hasError = false;
            try {
              result = pyodide.runPython(code);
            } catch (e: any) {
              hasError = true;
              result = e.message;
            }

            const stdout = pyodide.runPython('__stdout_capture.getvalue()');
            const stderr = pyodide.runPython('__stderr_capture.getvalue()');

            // Restore stdout/stderr
            pyodide.runPython(`
sys.stdout = sys.__stdout__
sys.stderr = sys.__stderr__
`);

            // Build output
            let outputText = '';
            if (stdout) outputText += stdout;
            if (stderr) outputText += stderr;
            if (hasError) {
              outputEl.innerHTML = `<span class="output-label">Output</span><span class="error-text">${escapeHtml(String(result))}</span>`;
            } else {
              if (!outputText && result !== undefined && result !== null) {
                outputText = String(result);
              }
              if (outputText) {
                outputEl.innerHTML = `<span class="output-label">Output</span>${escapeHtml(outputText)}`;
              } else {
                outputEl.innerHTML = `<span class="output-label">Output</span><span style="color:#5c5f66;font-style:italic;">No output</span>`;
              }
            }

            // Move output after toolbar, adjust borders
            toolbar.style.borderBottomLeftRadius = '0';
            toolbar.style.borderBottomRightRadius = '0';
            toolbar.style.borderBottom = 'none';

            if (!wrapper.contains(outputEl)) {
              wrapper.appendChild(outputEl);
            }
            outputEl.style.display = 'block';
          } catch (e: any) {
            if (banner) banner.remove();
            outputEl.innerHTML = `<span class="output-label">Error</span><span class="error-text">${escapeHtml(e.message)}</span>`;
            toolbar.style.borderBottomLeftRadius = '0';
            toolbar.style.borderBottomRightRadius = '0';
            toolbar.style.borderBottom = 'none';
            if (!wrapper.contains(outputEl)) {
              wrapper.appendChild(outputEl);
            }
            outputEl.style.display = 'block';
          } finally {
            runBtn.classList.remove('loading');
            runBtn.disabled = false;
          }
        });
      });
    }

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', initCodeRunners);
    // Also handle Astro view transitions
    document.addEventListener('astro:page-load', initCodeRunners);
  </script>
</BaseLayout>
