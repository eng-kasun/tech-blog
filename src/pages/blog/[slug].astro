---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryIcons: Record<string, string> = {
  'computer-science': '💻',
  'space-technology': '🚀',
  'artificial-intelligence': '🤖',
  'quantum-physics': '⚛️',
  'nature': '🌿',
};

const icon = categoryIcons[post.data.category] || '📝';
const formattedDate = post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Back link -->
    <a href="/tech-blog/blog/" class="inline-flex items-center gap-1 text-dark-300 hover:text-primary-300 text-sm mb-8 transition-colors">
      ← Back to articles
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold tracking-widest uppercase text-primary-300">
          {icon} {post.data.category.replace(/-/g, ' ')}
        </span>
        <span class="text-dark-400">·</span>
        <time class="text-dark-300 text-sm">{formattedDate}</time>
      </div>

      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-dark-50 leading-tight mb-4">
        {post.data.title}
      </h1>

      <p class="text-dark-200 text-lg leading-relaxed">
        {post.data.description}
      </p>

      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="px-2.5 py-0.5 rounded-md bg-dark-700 border border-dark-500/40 text-dark-200 text-xs">#{tag}</span>
          ))}
        </div>
      )}

      <div class="h-px bg-dark-500/40 mt-8"></div>

      {post.data.image && (
        <div class="mt-8 rounded-lg overflow-hidden border border-dark-500/30">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-64 sm:h-80 md:h-96 object-cover"
            style="filter: sepia(0.15) saturate(0.9);"
          />
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="prose max-w-none">
      <Content />
    </div>
  </article>

  <!-- Interactive Python Runner (Pyodide) -->
  <style is:global>
    /* ── Reset prose interference ── */
    .code-runner-wrapper,
    .code-runner-wrapper * {
      line-height: normal;
    }
    .code-runner-wrapper svg {
      display: inline-block;
      vertical-align: middle;
      flex-shrink: 0;
      margin: 0;
      padding: 0;
    }

    /* ── Wrapper ── */
    .code-runner-wrapper {
      position: relative;
      margin-bottom: 1.5rem;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid #383838;
      background: #1e1e1e;
    }
    .code-runner-wrapper pre {
      margin: 0 !important;
      border: none !important;
      border-radius: 0 !important;
      padding: 1rem !important;
    }

    /* ── macOS Title Bar ── */
    .cr-titlebar {
      display: flex;
      align-items: center;
      height: 36px;
      padding: 0 12px;
      background: #2d2d2d;
      border-bottom: 1px solid #383838;
      user-select: none;
    }
    .cr-dots {
      display: flex;
      align-items: center;
      gap: 7px;
    }
    .cr-dot {
      width: 11px;
      height: 11px;
      border-radius: 50%;
      border: 0.5px solid rgba(0,0,0,0.15);
    }
    .cr-dot-red { background: #ff5f57; }
    .cr-dot-yellow { background: #febc2e; }
    .cr-dot-green { background: #28c840; }
    .cr-title {
      flex: 1;
      text-align: center;
      font-size: 12px;
      font-family: -apple-system, 'Inter', system-ui, sans-serif;
      color: #8e8e8e;
      font-weight: 400;
      letter-spacing: 0.01em;
    }
    .cr-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      font-size: 10px;
      font-family: 'SF Mono', 'JetBrains Mono', monospace;
      font-weight: 500;
      color: #4b8bbe;
      background: rgba(75, 139, 190, 0.1);
      border-radius: 4px;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    /* ── Action Bar ── */
    .cr-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      height: 40px;
      padding: 0 12px;
      background: #252526;
      border-top: 1px solid #383838;
    }
    .cr-run {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      height: 28px;
      padding: 0 14px;
      font-size: 12px;
      font-weight: 600;
      font-family: -apple-system, 'Inter', system-ui, sans-serif;
      color: #fff;
      background: #28c840;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .cr-run:hover {
      background: #34d058;
    }
    .cr-run:active {
      background: #22a636;
      transform: scale(0.97);
    }
    .cr-run.is-loading {
      opacity: 0.6;
      cursor: wait;
    }
    .cr-run .cr-icon-play { display: inline-flex; align-items: center; }
    .cr-run .cr-icon-spin { display: none; align-items: center; }
    .cr-run.is-loading .cr-icon-play { display: none; }
    .cr-run.is-loading .cr-icon-spin { display: inline-flex; }
    .cr-reset {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      height: 28px;
      padding: 0 10px;
      font-size: 11px;
      font-weight: 500;
      font-family: -apple-system, 'Inter', system-ui, sans-serif;
      color: #8e8e8e;
      background: transparent;
      border: 1px solid #484848;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .cr-reset:hover {
      color: #ccc;
      border-color: #666;
      background: rgba(255,255,255,0.04);
    }
    .cr-divider {
      width: 1px;
      height: 16px;
      background: #484848;
    }
    .cr-hint {
      margin-left: auto;
      font-size: 11px;
      font-family: -apple-system, 'Inter', system-ui, sans-serif;
      color: #666;
    }
    .cr-hint kbd {
      display: inline;
      padding: 1px 5px;
      font-size: 10px;
      font-family: 'SF Mono', 'JetBrains Mono', monospace;
      color: #8e8e8e;
      background: #333;
      border: 1px solid #484848;
      border-radius: 3px;
    }

    /* ── Output ── */
    .cr-output {
      margin: 0;
      background: #1a1a1a;
      border-top: 1px solid #383838;
      font-family: 'SF Mono', 'JetBrains Mono', monospace;
      font-size: 13px;
      line-height: 1.6;
      max-height: 300px;
      overflow-y: auto;
    }
    .cr-output-bar {
      display: flex;
      align-items: center;
      gap: 6px;
      height: 28px;
      padding: 0 12px;
      background: #222;
      border-bottom: 1px solid #2a2a2a;
    }
    .cr-output-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #28c840;
      box-shadow: 0 0 4px rgba(40, 200, 64, 0.4);
    }
    .cr-output-dot.is-error {
      background: #ff5f57;
      box-shadow: 0 0 4px rgba(255, 95, 87, 0.4);
    }
    .cr-output-bar span {
      font-size: 10px;
      font-family: 'SF Mono', 'JetBrains Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #666;
      font-weight: 600;
    }
    .cr-output-body {
      padding: 10px 14px;
      color: #4ec9b0;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .cr-output-body .err { color: #f48771; }
    .cr-output-body .muted { color: #555; font-style: italic; }

    /* ── Loading ── */
    .cr-loading {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      font-size: 12px;
      font-family: -apple-system, 'Inter', system-ui, sans-serif;
      color: #cca700;
      background: rgba(204, 167, 0, 0.05);
      border-top: 1px solid rgba(204, 167, 0, 0.1);
    }
    .cr-loading small {
      display: block;
      font-size: 11px;
      color: #777;
      margin-top: 2px;
    }
    .cr-spinner {
      width: 14px;
      height: 14px;
      border: 2px solid rgba(255,255,255,0.08);
      border-top-color: #cca700;
      border-radius: 50%;
      animation: cr-spin 0.6s linear infinite;
      flex-shrink: 0;
    }
    .cr-spinner-green {
      border-top-color: #28c840;
    }
    @keyframes cr-spin {
      to { transform: rotate(360deg); }
    }

    /* ── Editable code ── */
    .code-runner-wrapper pre code {
      outline: none;
    }
    .code-runner-wrapper pre code:focus {
      box-shadow: inset 0 0 0 1px rgba(75, 139, 190, 0.2);
    }
  </style>

  <script>
    let pyodideInstance: any = null;
    let pyodideLoading = false;
    const loadingCallbacks: (() => void)[] = [];

    async function loadPyodideRuntime() {
      if (pyodideInstance) return pyodideInstance;
      if (pyodideLoading) {
        return new Promise<any>((resolve) => {
          loadingCallbacks.push(() => resolve(pyodideInstance));
        });
      }

      pyodideLoading = true;

      // Load the Pyodide script
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/pyodide/v0.25.1/full/pyodide.js';
      document.head.appendChild(script);

      await new Promise<void>((resolve, reject) => {
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('Failed to load Pyodide'));
      });

      // @ts-ignore - loadPyodide is loaded via script tag
      pyodideInstance = await (window as any).loadPyodide({
        indexURL: 'https://cdn.jsdelivr.net/pyodide/v0.25.1/full/',
      });

      pyodideLoading = false;
      loadingCallbacks.forEach((cb) => cb());
      loadingCallbacks.length = 0;

      return pyodideInstance;
    }

    function initCodeRunners() {
      const preTags = document.querySelectorAll('.prose pre[data-language="python"]');

      preTags.forEach((pre) => {
        const codeEl = pre.querySelector('code');
        if (!codeEl || pre.closest('.code-runner-wrapper')) return;

        const originalCode = (codeEl as HTMLElement).innerText;

        // Wrap pre in a container
        const wrapper = document.createElement('div');
        wrapper.className = 'code-runner-wrapper';
        pre.parentNode!.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        // Make code editable
        (codeEl as HTMLElement).contentEditable = 'true';
        (codeEl as HTMLElement).spellcheck = false;

        // ── macOS Title Bar ──
        const titlebar = document.createElement('div');
        titlebar.className = 'cr-titlebar';
        titlebar.innerHTML = `<div class="cr-dots"><div class="cr-dot cr-dot-red"></div><div class="cr-dot cr-dot-yellow"></div><div class="cr-dot cr-dot-green"></div></div><span class="cr-title">python — editable</span><span class="cr-badge">&#x1F40D; py</span>`;
        wrapper.insertBefore(titlebar, pre);

        // ── Action Bar ──
        const actions = document.createElement('div');
        actions.className = 'cr-actions';

        const runBtn = document.createElement('button');
        runBtn.className = 'cr-run';
        runBtn.innerHTML = `<span class="cr-icon-play"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span><span class="cr-icon-spin"><span class="cr-spinner cr-spinner-green"></span></span>Run`;

        const resetBtn = document.createElement('button');
        resetBtn.className = 'cr-reset';
        resetBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 105.64-11.36L1 10"/></svg>Reset`;

        const divider = document.createElement('div');
        divider.className = 'cr-divider';

        const hint = document.createElement('span');
        hint.className = 'cr-hint';
        hint.innerHTML = `Click <kbd>Run</kbd> or edit code above`;

        actions.appendChild(runBtn);
        actions.appendChild(resetBtn);
        actions.appendChild(divider);
        actions.appendChild(hint);
        wrapper.appendChild(actions);

        // Output area (hidden initially)
        const outputEl = document.createElement('div');
        outputEl.className = 'cr-output';
        outputEl.style.display = 'none';

        // Reset handler
        resetBtn.addEventListener('click', () => {
          (codeEl as HTMLElement).innerText = originalCode;
          outputEl.style.display = 'none';
          outputEl.innerHTML = '';
        });

        // Run handler
        runBtn.addEventListener('click', async () => {
          const code = (codeEl as HTMLElement).innerText;
          runBtn.classList.add('is-loading');
          (runBtn as HTMLButtonElement).disabled = true;

          // Show loading banner on first load
          let banner: HTMLElement | null = null;
          if (!pyodideInstance) {
            banner = document.createElement('div');
            banner.className = 'cr-loading';
            banner.innerHTML = `<span class="cr-spinner"></span><span>Loading Python runtime…<small>First run only — downloads ~10 MB (cached by browser)</small></span>`;
            wrapper.insertBefore(banner, actions.nextSibling);
          }

          try {
            const pyodide = await loadPyodideRuntime();
            if (banner) banner.remove();

            // Capture stdout and stderr
            pyodide.runPython(`
import sys, io
__stdout_capture = io.StringIO()
__stderr_capture = io.StringIO()
sys.stdout = __stdout_capture
sys.stderr = __stderr_capture
`);

            let result: any;
            let hasError = false;
            try {
              result = pyodide.runPython(code);
            } catch (e: any) {
              hasError = true;
              result = e.message;
            }

            const stdout = pyodide.runPython('__stdout_capture.getvalue()');
            const stderr = pyodide.runPython('__stderr_capture.getvalue()');

            // Restore stdout/stderr
            pyodide.runPython(`
sys.stdout = sys.__stdout__
sys.stderr = sys.__stderr__
`);

            // Build output
            let outputText = '';
            if (stdout) outputText += stdout;
            if (stderr) outputText += stderr;
            if (hasError) {
              outputEl.innerHTML = `<div class="cr-output-bar"><div class="cr-output-dot is-error"></div><span>Error</span></div><div class="cr-output-body"><span class="err">${escapeHtml(String(result))}</span></div>`;
            } else {
              if (!outputText && result !== undefined && result !== null) {
                outputText = String(result);
              }
              if (outputText) {
                outputEl.innerHTML = `<div class="cr-output-bar"><div class="cr-output-dot"></div><span>Output</span></div><div class="cr-output-body">${escapeHtml(outputText)}</div>`;
              } else {
                outputEl.innerHTML = `<div class="cr-output-bar"><div class="cr-output-dot"></div><span>Output</span></div><div class="cr-output-body"><span class="muted">No output</span></div>`;
              }
            }

            if (!wrapper.contains(outputEl)) {
              wrapper.appendChild(outputEl);
            }
            outputEl.style.display = 'block';
          } catch (e: any) {
            if (banner) banner.remove();
            outputEl.innerHTML = `<div class="cr-output-bar"><div class="cr-output-dot is-error"></div><span>Error</span></div><div class="cr-output-body"><span class="err">${escapeHtml(e.message)}</span></div>`;
            if (!wrapper.contains(outputEl)) {
              wrapper.appendChild(outputEl);
            }
            outputEl.style.display = 'block';
          } finally {
            runBtn.classList.remove('is-loading');
            (runBtn as HTMLButtonElement).disabled = false;
          }
        });
      });
    }

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', initCodeRunners);
    // Also handle Astro view transitions
    document.addEventListener('astro:page-load', initCodeRunners);
  </script>
</BaseLayout>
