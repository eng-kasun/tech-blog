---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryColors: Record<string, string> = {
  'computer-science': 'from-blue-500 to-cyan-500',
  'space-technology': 'from-violet-500 to-purple-500',
  'artificial-intelligence': 'from-primary-500 to-accent-500',
  'quantum-physics': 'from-rose-500 to-orange-500',
  'nature': 'from-green-500 to-emerald-500',
};

const categoryIcons: Record<string, string> = {
  'computer-science': '💻',
  'space-technology': '🚀',
  'artificial-intelligence': '🤖',
  'quantum-physics': '⚛️',
  'nature': '🌿',
};

const gradient = categoryColors[post.data.category] || 'from-primary-500 to-accent-500';
const icon = categoryIcons[post.data.category] || '📝';
const formattedDate = post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Back link -->
    <a href="/tech-blog/blog/" class="inline-flex items-center gap-1 text-dark-300 hover:text-primary-400 text-sm mb-8 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to articles
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-gradient-to-r ${gradient} text-white`}>
          <span>{icon}</span>
          {post.data.category.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}
        </span>
        <time class="text-dark-300 text-sm">{formattedDate}</time>
      </div>

      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
        {post.data.title}
      </h1>

      <p class="text-dark-200 text-lg leading-relaxed">
        {post.data.description}
      </p>

      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="px-2.5 py-0.5 rounded-md bg-dark-600 text-dark-200 text-xs">#{tag}</span>
          ))}
        </div>
      )}

      <div class={`h-px bg-gradient-to-r ${gradient} mt-8 opacity-30`}></div>

      {post.data.image && (
        <div class="mt-8 rounded-2xl overflow-hidden border border-dark-500/30">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-64 sm:h-80 md:h-96 object-cover"
          />
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="prose max-w-none">
      <Content />
    </div>
  </article>

  <!-- Interactive Python Runner (Pyodide) -->
  <style>
    .code-runner-wrapper {
      position: relative;
      margin-bottom: 1.5rem;
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid #2c2e33;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
    }
    .code-runner-wrapper pre {
      margin: 0 !important;
      border: none !important;
      border-radius: 0 !important;
    }

    /* ── Language Header Bar ── */
    .code-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: linear-gradient(180deg, #1e1f22, #1a1b1e);
      border-bottom: 1px solid #2c2e33;
    }
    .code-header-dots {
      display: flex;
      gap: 6px;
    }
    .code-header-dots span {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .code-header-dots span:nth-child(1) { background: #ff5f57; }
    .code-header-dots span:nth-child(2) { background: #febc2e; }
    .code-header-dots span:nth-child(3) { background: #28c840; }
    .code-header-lang {
      margin-left: auto;
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.2rem 0.625rem;
      font-size: 0.6875rem;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 500;
      color: #ffd43b;
      background: rgba(255, 212, 59, 0.08);
      border: 1px solid rgba(255, 212, 59, 0.12);
      border-radius: 999px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .code-header-lang svg {
      width: 12px;
      height: 12px;
    }
    .code-header-editable {
      font-size: 0.6875rem;
      color: #5c5f66;
      font-family: 'Inter', system-ui, sans-serif;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .code-header-editable svg {
      width: 11px;
      height: 11px;
    }

    /* ── Action Toolbar ── */
    .code-toolbar {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.625rem 1rem;
      background: linear-gradient(180deg, #141517, #101113);
      border-top: 1px solid #2c2e33;
    }
    .run-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1.25rem;
      font-size: 0.8125rem;
      font-weight: 600;
      font-family: 'Inter', system-ui, sans-serif;
      color: #fff;
      background: linear-gradient(135deg, #20c997, #0ca678);
      border: none;
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(32, 201, 151, 0.2);
    }
    .run-btn:hover {
      background: linear-gradient(135deg, #38d9a9, #20c997);
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(32, 201, 151, 0.35);
    }
    .run-btn:active {
      transform: translateY(0);
      box-shadow: 0 2px 8px rgba(32, 201, 151, 0.2);
    }
    .run-btn.loading {
      opacity: 0.7;
      cursor: wait;
      transform: none;
    }
    .run-btn svg {
      width: 14px;
      height: 14px;
    }
    .reset-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.5rem 0.875rem;
      font-size: 0.75rem;
      font-weight: 500;
      font-family: 'Inter', system-ui, sans-serif;
      color: #909296;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid #373a40;
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .reset-btn:hover {
      color: #c1c2c5;
      border-color: #5c5f66;
      background: rgba(255, 255, 255, 0.07);
    }
    .reset-btn svg {
      width: 13px;
      height: 13px;
    }
    .toolbar-separator {
      width: 1px;
      height: 20px;
      background: #373a40;
      margin: 0 0.25rem;
    }
    .toolbar-hint {
      font-size: 0.6875rem;
      color: #5c5f66;
      font-family: 'Inter', system-ui, sans-serif;
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .toolbar-hint kbd {
      display: inline-flex;
      align-items: center;
      padding: 0.125rem 0.375rem;
      font-size: 0.625rem;
      font-family: 'JetBrains Mono', monospace;
      color: #5c5f66;
      background: #25262b;
      border: 1px solid #373a40;
      border-radius: 0.25rem;
    }

    /* ── Output Panel ── */
    .code-output {
      margin: 0;
      padding: 0;
      background: #0d0e10;
      border-top: 1px solid #2c2e33;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8125rem;
      line-height: 1.7;
      max-height: 320px;
      overflow-y: auto;
    }
    .code-output-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: rgba(32, 201, 151, 0.04);
      border-bottom: 1px solid rgba(32, 201, 151, 0.08);
    }
    .code-output-header .output-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #20c997;
      box-shadow: 0 0 6px rgba(32, 201, 151, 0.5);
    }
    .code-output-header .output-dot.error {
      background: #ff6b6b;
      box-shadow: 0 0 6px rgba(255, 107, 107, 0.5);
    }
    .code-output-header span {
      font-size: 0.625rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #5c5f66;
      font-weight: 600;
    }
    .code-output-body {
      padding: 0.75rem 1rem;
      color: #63e6be;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .code-output-body .error-text {
      color: #ff6b6b;
    }
    .code-output-body .no-output {
      color: #5c5f66;
      font-style: italic;
    }

    /* ── Loading Banner ── */
    .pyodide-loading-banner {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.75rem 1rem;
      font-size: 0.8125rem;
      font-family: 'Inter', system-ui, sans-serif;
      color: #ffd43b;
      background: linear-gradient(90deg, rgba(255, 212, 59, 0.06), rgba(255, 212, 59, 0.02));
      border-top: 1px solid rgba(255, 212, 59, 0.1);
      animation: pulse-glow 2s ease-in-out infinite;
    }
    .pyodide-loading-banner .loading-text {
      flex: 1;
    }
    .pyodide-loading-banner .loading-text small {
      display: block;
      font-size: 0.6875rem;
      color: #909296;
      margin-top: 0.125rem;
    }
    @keyframes pulse-glow {
      0%, 100% { opacity: 0.8; }
      50% { opacity: 1; }
    }
    .spinner {
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255, 255, 255, 0.1);
      border-top-color: #20c997;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      flex-shrink: 0;
    }
    .spinner.yellow {
      border-top-color: #ffd43b;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .code-toolbar .run-btn .play-icon { display: inline-flex; }
    .code-toolbar .run-btn .spin-icon { display: none; }
    .code-toolbar .run-btn.loading .play-icon { display: none; }
    .code-toolbar .run-btn.loading .spin-icon { display: inline-flex; }

    /* ── Editable Code ── */
    .code-runner-wrapper pre code {
      outline: none;
    }
    .code-runner-wrapper pre code:focus {
      box-shadow: inset 0 0 0 1px rgba(92, 124, 250, 0.25);
    }
  </style>

  <script>
    let pyodideInstance: any = null;
    let pyodideLoading = false;
    const loadingCallbacks: (() => void)[] = [];

    async function loadPyodideRuntime() {
      if (pyodideInstance) return pyodideInstance;
      if (pyodideLoading) {
        return new Promise<any>((resolve) => {
          loadingCallbacks.push(() => resolve(pyodideInstance));
        });
      }

      pyodideLoading = true;

      // Load the Pyodide script
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/pyodide/v0.25.1/full/pyodide.js';
      document.head.appendChild(script);

      await new Promise<void>((resolve, reject) => {
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('Failed to load Pyodide'));
      });

      // @ts-ignore - loadPyodide is loaded via script tag
      pyodideInstance = await (window as any).loadPyodide({
        indexURL: 'https://cdn.jsdelivr.net/pyodide/v0.25.1/full/',
      });

      pyodideLoading = false;
      loadingCallbacks.forEach((cb) => cb());
      loadingCallbacks.length = 0;

      return pyodideInstance;
    }

    function initCodeRunners() {
      const preTags = document.querySelectorAll('.prose pre[data-language="python"]');

      preTags.forEach((pre) => {
        const codeEl = pre.querySelector('code');
        if (!codeEl || pre.closest('.code-runner-wrapper')) return;

        const originalCode = (codeEl as HTMLElement).innerText;

        // Wrap pre in a container
        const wrapper = document.createElement('div');
        wrapper.className = 'code-runner-wrapper';
        pre.parentNode!.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        // Make code editable
        (codeEl as HTMLElement).contentEditable = 'true';
        (codeEl as HTMLElement).spellcheck = false;

        // ── Header bar (dots + language badge) ──
        const header = document.createElement('div');
        header.className = 'code-header';
        header.innerHTML = `
          <div class="code-header-dots"><span></span><span></span><span></span></div>
          <span class="code-header-editable">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            editable
          </span>
          <span class="code-header-lang">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06.01h8.16v-.83H6.18l-.01-2.75-.02-.37.05-.34.11-.31.17-.28.25-.26.31-.23.38-.2.44-.18.51-.15.58-.12.64-.1.71-.06.77-.04.84-.02 1.27.05zm-6.3 1.98l-.23.33-.08.41.08.41.23.34.33.22.41.09.41-.09.33-.22.23-.34.08-.41-.08-.41-.23-.33-.33-.22-.41-.09-.41.09zm13.09 3.95l.28.06.32.12.35.18.36.27.36.35.35.47.32.59.28.73.21.88.14 1.04.05 1.23-.06 1.23-.16 1.04-.24.86-.32.71-.36.57-.4.45-.42.33-.42.24-.4.16-.36.09-.32.05-.24.02-.16-.01h-8.22v.82h5.84l.01 2.76.02.36-.05.34-.11.31-.17.29-.25.25-.31.24-.38.2-.44.17-.51.15-.58.13-.64.09-.71.07-.77.04-.84.01-1.27-.04-1.07-.14-.9-.2-.73-.25-.59-.3-.45-.33-.34-.34-.25-.34-.16-.33-.1-.3-.04-.25-.02-.2.01-.13v-5.34l.05-.64.13-.54.21-.46.26-.38.3-.32.33-.24.35-.2.35-.14.33-.1.3-.06.26-.04.21-.02.13-.01h5.84l.69-.05.59-.14.5-.21.41-.28.33-.32.27-.35.2-.36.15-.36.1-.35.07-.32.04-.28.02-.21V6.07h2.09l.14.01zm-6.47 14.25l-.23.33-.08.41.08.41.23.33.33.23.41.08.41-.08.33-.23.23-.33.08-.41-.08-.41-.23-.33-.33-.23-.41-.08-.41.08z"/></svg>
            Python
          </span>
        `;
        wrapper.insertBefore(header, pre);

        // ── Action Toolbar ──
        const toolbar = document.createElement('div');
        toolbar.className = 'code-toolbar';

        const runBtn = document.createElement('button');
        runBtn.className = 'run-btn';
        runBtn.innerHTML = `
          <span class="play-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
          <span class="spin-icon"><span class="spinner"></span></span>
          Run
        `;

        const resetBtn = document.createElement('button');
        resetBtn.className = 'reset-btn';
        resetBtn.innerHTML = `
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 105.64-11.36L1 10"/></svg>
          Reset
        `;

        const separator = document.createElement('div');
        separator.className = 'toolbar-separator';

        const hint = document.createElement('span');
        hint.className = 'toolbar-hint';
        hint.innerHTML = `Click <kbd>Run</kbd> or edit the code above`;

        toolbar.appendChild(runBtn);
        toolbar.appendChild(resetBtn);
        toolbar.appendChild(separator);
        toolbar.appendChild(hint);
        wrapper.appendChild(toolbar);

        // Output area (hidden initially)
        const outputEl = document.createElement('div');
        outputEl.className = 'code-output';
        outputEl.style.display = 'none';

        // Reset handler
        resetBtn.addEventListener('click', () => {
          (codeEl as HTMLElement).innerText = originalCode;
          outputEl.style.display = 'none';
          outputEl.innerHTML = '';
          // Move toolbar back to right after pre
          wrapper.insertBefore(toolbar, outputEl);
        });

        // Run handler
        runBtn.addEventListener('click', async () => {
          const code = (codeEl as HTMLElement).innerText;
          runBtn.classList.add('loading');
          runBtn.disabled = true;

          // Show loading banner on first load
          let banner: HTMLElement | null = null;
          if (!pyodideInstance) {
            banner = document.createElement('div');
            banner.className = 'pyodide-loading-banner';
            banner.innerHTML = `
              <span class="spinner yellow"></span>
              <span class="loading-text">
                Loading Python runtime…
                <small>First run only — downloads ~10 MB WebAssembly (cached by browser)</small>
              </span>
            `;
            wrapper.insertBefore(banner, toolbar.nextSibling);
          }

          try {
            const pyodide = await loadPyodideRuntime();
            if (banner) banner.remove();

            // Capture stdout and stderr
            pyodide.runPython(`
import sys, io
__stdout_capture = io.StringIO()
__stderr_capture = io.StringIO()
sys.stdout = __stdout_capture
sys.stderr = __stderr_capture
`);

            let result: any;
            let hasError = false;
            try {
              result = pyodide.runPython(code);
            } catch (e: any) {
              hasError = true;
              result = e.message;
            }

            const stdout = pyodide.runPython('__stdout_capture.getvalue()');
            const stderr = pyodide.runPython('__stderr_capture.getvalue()');

            // Restore stdout/stderr
            pyodide.runPython(`
sys.stdout = sys.__stdout__
sys.stderr = sys.__stderr__
`);

            // Build output
            let outputText = '';
            if (stdout) outputText += stdout;
            if (stderr) outputText += stderr;
            if (hasError) {
              outputEl.innerHTML = `
                <div class="code-output-header"><span class="output-dot error"></span><span>Error</span></div>
                <div class="code-output-body"><span class="error-text">${escapeHtml(String(result))}</span></div>
              `;
            } else {
              if (!outputText && result !== undefined && result !== null) {
                outputText = String(result);
              }
              if (outputText) {
                outputEl.innerHTML = `
                  <div class="code-output-header"><span class="output-dot"></span><span>Output</span></div>
                  <div class="code-output-body">${escapeHtml(outputText)}</div>
                `;
              } else {
                outputEl.innerHTML = `
                  <div class="code-output-header"><span class="output-dot"></span><span>Output</span></div>
                  <div class="code-output-body"><span class="no-output">No output</span></div>
                `;
              }
            }

            if (!wrapper.contains(outputEl)) {
              wrapper.appendChild(outputEl);
            }
            outputEl.style.display = 'block';
          } catch (e: any) {
            if (banner) banner.remove();
            outputEl.innerHTML = `
              <div class="code-output-header"><span class="output-dot error"></span><span>Error</span></div>
              <div class="code-output-body"><span class="error-text">${escapeHtml(e.message)}</span></div>
            `;
            if (!wrapper.contains(outputEl)) {
              wrapper.appendChild(outputEl);
            }
            outputEl.style.display = 'block';
          } finally {
            runBtn.classList.remove('loading');
            runBtn.disabled = false;
          }
        });
      });
    }

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', initCodeRunners);
    // Also handle Astro view transitions
    document.addEventListener('astro:page-load', initCodeRunners);
  </script>
</BaseLayout>
