---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="All Articles">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8">
      <div class="rule-thick mb-1"></div>
      <div class="rule-thin mb-4"></div>
      <h1 class="font-headline text-4xl font-black text-paper-100 mb-2">All Articles</h1>
      <p class="text-paper-500 text-sm font-body">Complete archive of dispatches from The TechVerse.</p>
    </div>

    {allPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-6">
        {allPosts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toISOString()}
            category={post.data.category}
            slug={post.slug}
            image={post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 border border-dark-300">
        <p class="text-paper-500 text-lg font-headline italic">No dispatches yet.</p>
      </div>
    )}
  </div>
</BaseLayout>
