---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const categories = [
  { name: 'Computer Science', slug: 'computer-science', icon: '💻', gradient: 'from-blue-500 to-cyan-500' },
  { name: 'Space Technology', slug: 'space-technology', icon: '🚀', gradient: 'from-violet-500 to-purple-500' },
  { name: 'Artificial Intelligence', slug: 'artificial-intelligence', icon: '🤖', gradient: 'from-primary-500 to-accent-500' },
  { name: 'Quantum Physics', slug: 'quantum-physics', icon: '⚛️', gradient: 'from-rose-500 to-orange-500' },
  { name: 'Nature', slug: 'nature', icon: '🌿', gradient: 'from-green-500 to-emerald-500' },
];

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(p => p.data.category === cat.slug).length,
}));
---

<BaseLayout title="Categories">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8">
      <div class="rule-thick mb-1"></div>
      <div class="rule-thin mb-4"></div>
      <h1 class="font-headline text-4xl font-black text-paper-100 mb-2">Sections</h1>
      <p class="text-paper-500 text-sm font-body">Browse The TechVerse by topic.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {categoryCounts.map(cat => (
        <CategoryCard {...cat} />
      ))}
    </div>
  </div>
</BaseLayout>
