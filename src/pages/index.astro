---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPosts = allPosts.filter(p => p.data.featured).slice(0, 2);
const latestPosts = allPosts.slice(0, 6);

const categories = [
  { name: 'Computer Science', slug: 'computer-science', icon: '💻', gradient: 'from-blue-500 to-cyan-500' },
  { name: 'Space Technology', slug: 'space-technology', icon: '🚀', gradient: 'from-violet-500 to-purple-500' },
  { name: 'Artificial Intelligence', slug: 'artificial-intelligence', icon: '🤖', gradient: 'from-primary-500 to-accent-500' },
  { name: 'Quantum Physics', slug: 'quantum-physics', icon: '⚛️', gradient: 'from-rose-500 to-orange-500' },
  { name: 'Nature', slug: 'nature', icon: '🌿', gradient: 'from-green-500 to-emerald-500' },
];

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(p => p.data.category === cat.slug).length,
}));
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Warm subtle glow -->
    <div class="absolute inset-0">
      <div class="absolute top-20 left-1/4 w-96 h-96 bg-primary-500/8 rounded-full blur-3xl animate-warm-glow"></div>
      <div class="absolute top-32 right-1/4 w-80 h-80 bg-accent-500/6 rounded-full blur-3xl animate-warm-glow" style="animation-delay: -4s;"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20">
      <div class="text-center">
        <div class="ornament mb-8">❧</div>

        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold mb-6 leading-tight text-dark-50">
          Exploring the
          <em class="text-primary-300 not-italic">Frontiers</em><br />
          of Science &amp; Technology
        </h1>

        <p class="text-lg text-dark-200 mb-10 leading-relaxed max-w-2xl mx-auto">
          Dive into the latest breakthroughs in computer science, space exploration, artificial intelligence,
          quantum physics, and the wonders of nature.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/tech-blog/blog/" class="inline-flex items-center justify-center px-7 py-3 rounded-lg bg-primary-500 hover:bg-primary-600 text-white font-medium transition-colors">
            Explore Articles
            <span class="ml-2">→</span>
          </a>
          <a href="/tech-blog/categories/" class="inline-flex items-center justify-center px-7 py-3 rounded-lg border border-dark-400 text-dark-100 hover:bg-dark-600/40 hover:border-dark-300 font-medium transition-all">
            Browse Categories
          </a>
        </div>

        <div class="ornament mt-12">✦</div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-display text-2xl font-bold text-dark-50">Topics</h2>
      <a href="/tech-blog/categories/" class="text-primary-300 hover:text-primary-200 text-sm font-medium transition-colors">
        View all →
      </a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
      {categoryCounts.map(cat => (
        <CategoryCard {...cat} />
      ))}
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-display text-2xl font-bold text-dark-50">Latest Articles</h2>
      <a href="/tech-blog/blog/" class="text-primary-300 hover:text-primary-200 text-sm font-medium transition-colors">
        View all →
      </a>
    </div>

    {latestPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestPosts.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toISOString()}
            category={post.data.category}
            slug={post.slug}
            image={post.data.image}
            featured={i === 0 && post.data.featured}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 rounded-lg border border-dashed border-dark-500">
        <p class="text-dark-300 text-lg">No posts yet. Create a GitHub Issue to generate your first AI-powered article!</p>
      </div>
    )}
  </section>

  <!-- How It Works -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="ornament mb-10">❧</div>
    <h2 class="font-display text-2xl font-bold text-dark-50 text-center mb-12">How TechVerse Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        { step: '01', title: 'Create an Issue', desc: 'Open a GitHub Issue with your topic idea and label it "generate-post"', icon: '📝' },
        { step: '02', title: 'AI Generates Content', desc: 'Google Gemini writes a comprehensive, well-structured article automatically', icon: '🤖' },
        { step: '03', title: 'Auto Published', desc: 'The article is committed, built, and deployed to your live site', icon: '🚀' },
      ].map(item => (
        <div class="relative p-6 rounded-lg bg-dark-700/20 border border-dark-500/40">
          <span class="text-5xl font-display font-bold text-dark-500/40 absolute top-4 right-4">{item.step}</span>
          <span class="text-3xl mb-4 block">{item.icon}</span>
          <h3 class="font-display font-semibold text-dark-50 text-lg mb-2">{item.title}</h3>
          <p class="text-dark-200 text-sm">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
