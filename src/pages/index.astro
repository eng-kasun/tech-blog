---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = allPosts[0];
const sidebarPosts = allPosts.slice(1, 4);
const morePosts = allPosts.slice(4, 10);

const categories = [
  { name: 'Computer Science', slug: 'computer-science', icon: '💻', gradient: '' },
  { name: 'Space Technology', slug: 'space-technology', icon: '🚀', gradient: '' },
  { name: 'Artificial Intelligence', slug: 'artificial-intelligence', icon: '🤖', gradient: '' },
  { name: 'Quantum Physics', slug: 'quantum-physics', icon: '⚛️', gradient: '' },
  { name: 'Nature', slug: 'nature', icon: '🌿', gradient: '' },
];

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(p => p.data.category === cat.slug).length,
}));

const today = new Date();
const vol = today.getFullYear() - 2025 + 1;
const issue = Math.ceil((today.getMonth() + 1) * 30 + today.getDate());
---

<BaseLayout title="Front Page">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    {/* Volume / Issue line */}
    <div class="flex items-center justify-between py-2 text-[10px] font-sans text-ink-300 uppercase tracking-[0.15em]">
      <span>Vol. {vol} — No. {issue}</span>
      <span>— ✦ —</span>
      <span>{allPosts.length} Articles Published</span>
    </div>

    <div class="rule-thick mb-1"></div>
    <div class="rule-thin mb-6"></div>

    {allPosts.length > 0 ? (
      <>
        {/* ── LEAD STORY + SIDEBAR ── */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 mb-0">

          {/* Lead story — 2 columns */}
          <div class="md:col-span-2 md:pr-6 md:border-r border-ink-200 pb-6">
            <a href={`/tech-blog/blog/${featuredPost.slug}/`} class="group block">
              {featuredPost.data.image && (
                <div class="mb-4 border border-ink-200 overflow-hidden">
                  <img
                    src={featuredPost.data.image}
                    alt={featuredPost.data.title}
                    class="w-full h-52 md:h-72 object-cover grayscale hover:grayscale-0 transition-all duration-500"
                  />
                </div>
              )}
              <span class="text-[10px] font-sans font-bold uppercase tracking-[0.2em] text-accent">
                {featuredPost.data.category.replace(/-/g, ' ')} — Lead Story
              </span>
              <h2 class="font-headline font-black text-ink-800 text-3xl sm:text-4xl md:text-5xl leading-[1.1] mt-2 mb-3 group-hover:text-accent transition-colors">
                {featuredPost.data.title}
              </h2>
              <p class="text-ink-500 font-body text-base leading-relaxed mb-3">
                {featuredPost.data.description}
              </p>
              <div class="flex items-center gap-2 text-[11px] font-sans text-ink-300">
                <time>{featuredPost.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                <span>·</span>
                <span class="italic">Continue reading →</span>
              </div>
            </a>
          </div>

          {/* Sidebar — 1 column */}
          <div class="md:pl-6 pt-6 md:pt-0">
            <h3 class="font-sans font-bold text-[10px] uppercase tracking-[0.2em] text-ink-400 mb-4 pb-2 border-b-2 border-ink-700">
              Also in this Edition
            </h3>
            <div class="space-y-4">
              {sidebarPosts.map((post, i) => (
                <a href={`/tech-blog/blog/${post.slug}/`} class="group block pb-4 border-b border-dotted border-ink-200 last:border-b-0">
                  <span class="text-[10px] font-sans font-bold uppercase tracking-[0.15em] text-accent">
                    {post.data.category.replace(/-/g, ' ')}
                  </span>
                  <h4 class="font-headline font-bold text-ink-800 text-base leading-snug mt-1 group-hover:text-accent transition-colors">
                    {post.data.title}
                  </h4>
                  <p class="text-ink-400 text-xs font-body mt-1 line-clamp-2">
                    {post.data.description}
                  </p>
                </a>
              ))}
            </div>

            {/* Info box — newspaper ad style */}
            <div class="mt-6 border-2 border-ink-700 p-4 text-center">
              <p class="font-headline font-black text-ink-800 text-lg leading-tight">AI-Powered</p>
              <p class="font-headline italic text-ink-500 text-sm mt-1">Every article written</p>
              <p class="font-headline italic text-ink-500 text-sm">by artificial intelligence</p>
              <div class="rule-dotted my-3"></div>
              <p class="font-sans text-[10px] uppercase tracking-widest text-ink-400">Google Gemini 2.0 Flash</p>
            </div>
          </div>
        </div>

        {/* ── SECTIONS / CATEGORIES ── */}
        <div class="rule-thick mt-6 mb-1"></div>
        <div class="rule-thin mb-4"></div>

        <div class="mb-6">
          <h3 class="font-sans font-bold text-[10px] uppercase tracking-[0.2em] text-ink-400 mb-4">Sections</h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
            {categoryCounts.map(cat => (
              <CategoryCard {...cat} />
            ))}
          </div>
        </div>

        {/* ── MORE STORIES ── */}
        {morePosts.length > 0 && (
          <>
            <div class="rule-thick mt-6 mb-1"></div>
            <div class="rule-thin mb-4"></div>

            <h3 class="font-sans font-bold text-[10px] uppercase tracking-[0.2em] text-ink-400 mb-6">
              More Stories
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-6">
              {morePosts.map(post => (
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.date.toISOString()}
                  category={post.data.category}
                  slug={post.slug}
                  image={post.data.image}
                />
              ))}
            </div>
          </>
        )}

        {/* ── HOW IT WORKS — classified ad style ── */}
        <div class="rule-thick mt-8 mb-1"></div>
        <div class="rule-thin mb-4"></div>

        <h3 class="font-sans font-bold text-[10px] uppercase tracking-[0.2em] text-ink-400 mb-6 text-center">
          How The TechVerse Works
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 mb-8">
          {[
            { step: 'I.', title: 'Submit a Topic', desc: 'Open a GitHub Issue with your idea and label it "generate-post"' },
            { step: 'II.', title: 'AI Composes', desc: 'Google Gemini researches and writes a comprehensive, well-structured article' },
            { step: 'III.', title: 'Auto Published', desc: 'The article is committed, built, and deployed to this gazette automatically' },
          ].map((item, i) => (
            <div class:list={[
              'p-5 text-center',
              i < 2 ? 'md:border-r border-ink-200' : '',
            ]}>
              <span class="font-headline font-bold text-3xl text-ink-200 block mb-2">{item.step}</span>
              <h4 class="font-headline font-bold text-ink-800 text-base mb-2">{item.title}</h4>
              <p class="text-ink-400 text-sm font-body leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </>
    ) : (
      <div class="text-center py-20 border border-ink-200">
        <p class="font-headline text-ink-400 text-lg italic">No dispatches yet.</p>
        <p class="text-ink-300 text-sm font-body mt-2">Create a GitHub Issue to generate your first article.</p>
      </div>
    )}

    <div class="rule-thin mb-4"></div>
  </div>
</BaseLayout>
