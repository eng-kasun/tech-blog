---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPosts = allPosts.filter(p => p.data.featured).slice(0, 2);
const latestPosts = allPosts.slice(0, 6);

const categories = [
  { name: 'Computer Science', slug: 'computer-science', icon: '💻', gradient: 'from-blue-500 to-cyan-500' },
  { name: 'Space Technology', slug: 'space-technology', icon: '🚀', gradient: 'from-violet-500 to-purple-500' },
  { name: 'Artificial Intelligence', slug: 'artificial-intelligence', icon: '🤖', gradient: 'from-primary-500 to-accent-500' },
  { name: 'Quantum Physics', slug: 'quantum-physics', icon: '⚛️', gradient: 'from-rose-500 to-orange-500' },
  { name: 'Nature', slug: 'nature', icon: '🌿', gradient: 'from-green-500 to-emerald-500' },
];

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(p => p.data.category === cat.slug).length,
}));
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Animated background -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900/20 via-dark-900 to-accent-900/20"></div>
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary-500/20 rounded-full blur-3xl animate-float"></div>
      <div class="absolute top-40 right-10 w-96 h-96 bg-accent-500/15 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
      <div class="absolute bottom-10 left-1/3 w-64 h-64 bg-violet-500/15 rounded-full blur-3xl animate-float" style="animation-delay: -1.5s;"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-dark-600/60 border border-dark-500/50 text-sm text-dark-100 mb-6 backdrop-blur-sm">
          <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
          AI-Powered Knowledge Hub
        </div>

        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold mb-6 leading-tight">
          Exploring the
          <span class="bg-gradient-to-r from-primary-400 via-accent-400 to-primary-400 bg-clip-text text-transparent bg-[length:200%_auto] animate-gradient">
            Frontiers
          </span>
          of Science & Technology
        </h1>

        <p class="text-lg text-dark-200 mb-8 leading-relaxed max-w-2xl mx-auto">
          Dive into the latest breakthroughs in computer science, space exploration, artificial intelligence,
          quantum physics, and the wonders of nature.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/tech-blog/blog/" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-gradient-to-r from-primary-500 to-accent-500 text-white font-medium hover:opacity-90 transition-opacity">
            Explore Articles
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href="/tech-blog/categories/" class="inline-flex items-center justify-center px-6 py-3 rounded-xl border border-dark-400 text-dark-100 hover:bg-dark-600/50 font-medium transition-all">
            Browse Categories
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-display text-2xl font-bold text-white">Topics</h2>
      <a href="/tech-blog/categories/" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors">
        View all →
      </a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
      {categoryCounts.map(cat => (
        <CategoryCard {...cat} />
      ))}
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-display text-2xl font-bold text-white">Latest Articles</h2>
      <a href="/tech-blog/blog/" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors">
        View all →
      </a>
    </div>

    {latestPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestPosts.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date.toISOString()}
            category={post.data.category}
            slug={post.slug}
            image={post.data.image}
            featured={i === 0 && post.data.featured}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 rounded-2xl border border-dashed border-dark-500">
        <p class="text-dark-300 text-lg">No posts yet. Create a GitHub Issue to generate your first AI-powered article!</p>
      </div>
    )}
  </section>

  <!-- How It Works -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="font-display text-2xl font-bold text-white text-center mb-12">How TechVerse Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        { step: '01', title: 'Create an Issue', desc: 'Open a GitHub Issue with your topic idea and label it "generate-post"', icon: '📝' },
        { step: '02', title: 'AI Generates Content', desc: 'Google Gemini writes a comprehensive, well-structured article automatically', icon: '🤖' },
        { step: '03', title: 'Auto Published', desc: 'The article is committed, built, and deployed to your live site', icon: '🚀' },
      ].map(item => (
        <div class="relative p-6 rounded-2xl bg-dark-700/30 border border-dark-500/50">
          <span class="text-5xl font-display font-bold text-dark-600 absolute top-4 right-4">{item.step}</span>
          <span class="text-3xl mb-4 block">{item.icon}</span>
          <h3 class="font-display font-semibold text-white text-lg mb-2">{item.title}</h3>
          <p class="text-dark-200 text-sm">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
