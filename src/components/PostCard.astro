---
interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  slug: string;
  image?: string;
  featured?: boolean;
}

const { title, description, date, category, slug, image, featured = false } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class:list={[
  'group',
  featured ? 'md:col-span-2 md:row-span-2' : '',
]}>
  <a href={`/tech-blog/blog/${slug}/`} class="block h-full">
    {/* Featured articles get a big image */}
    {image && featured && (
      <div class="mb-3 overflow-hidden border border-dark-300">
        <img
          src={image}
          alt={title}
          class="w-full h-48 md:h-64 object-cover grayscale sepia-[0.2] contrast-[1.1] brightness-[0.85] hover:grayscale-0 hover:sepia-0 hover:contrast-100 hover:brightness-100 transition-all duration-500"
          loading="lazy"
        />
      </div>
    )}

    {/* Category & date line */}
    <div class="flex items-center gap-2 mb-2">
      <span class="text-[10px] font-sans font-bold uppercase tracking-[0.2em] text-accent">
        {category.replace(/-/g, ' ')}
      </span>
      <span class="text-ink-200">|</span>
      <time class="text-dark-50 text-[11px] font-sans">{formattedDate}</time>
    </div>

    {/* Headline */}
    <h3 class:list={[
      'font-headline font-bold text-paper-100 group-hover:text-accent transition-colors leading-tight mb-2',
      featured ? 'text-2xl md:text-3xl' : 'text-lg',
    ]}>
      {title}
    </h3>

    {/* Description — newspaper lead paragraph style */}
    <p class:list={[
      'text-paper-400 font-body leading-relaxed',
      featured ? 'text-base' : 'text-sm line-clamp-3',
    ]}>
      {description}
    </p>

    {/* Thin rule at bottom */}
    <div class="mt-4 border-b border-dark-300 border-dotted"></div>
  </a>
</article>
