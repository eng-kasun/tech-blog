---
interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  slug: string;
  image?: string;
  featured?: boolean;
}

const { title, description, date, category, slug, image, featured = false } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class:list={[
  'group relative rounded-lg overflow-hidden transition-all duration-300',
  'border border-dark-500/40 hover:border-primary-500/30',
  'bg-dark-700/30 hover:bg-dark-700/60',
  'hover:shadow-lg hover:shadow-primary-900/20',
  featured ? 'md:col-span-2 md:row-span-2' : '',
]}>
  <a href={`/tech-blog/blog/${slug}/`} class="block h-full">
    <!-- Image -->
    {image ? (
      <div class="relative overflow-hidden">
        <img
          src={image}
          alt={title}
          class:list={[
            'w-full object-cover transition-transform duration-500 group-hover:scale-105',
            featured ? 'h-48 md:h-64' : 'h-44',
          ]}
          loading="lazy"
          style="filter: sepia(0.15) saturate(0.9);"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-dark-700/80 via-transparent to-transparent"></div>
      </div>
    ) : (
      <div class="h-1 bg-gradient-to-r from-primary-500/60 to-accent-500/60"></div>
    )}

    <div class:list={['p-6', featured ? 'md:p-8' : '']}>
      <!-- Category & date -->
      <div class="flex items-center gap-3 mb-3">
        <span class="text-xs font-semibold tracking-widest uppercase text-primary-300">
          {category.replace(/-/g, ' ')}
        </span>
        <span class="text-dark-400">·</span>
        <time class="text-dark-300 text-xs">{formattedDate}</time>
      </div>

      <!-- Thin rule -->
      <div class="h-px bg-dark-500/40 mb-3"></div>

      <!-- Title -->
      <h3 class:list={[
        'font-display font-semibold text-dark-50 group-hover:text-primary-300 transition-colors mb-2',
        featured ? 'text-2xl md:text-3xl' : 'text-lg',
      ]}>
        {title}
      </h3>

      <!-- Description -->
      <p class:list={[
        'text-dark-200 leading-relaxed',
        featured ? 'text-base' : 'text-sm line-clamp-3',
      ]}>
        {description}
      </p>

      <!-- Read more -->
      <div class="mt-4 flex items-center gap-1 text-primary-300 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
        Read more
        <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
      </div>
    </div>
  </a>
</article>
