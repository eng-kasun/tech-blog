---
interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  slug: string;
  image?: string;
  featured?: boolean;
}

const { title, description, date, category, slug, image, featured = false } = Astro.props;

const categoryColors: Record<string, string> = {
  'computer-science': 'from-blue-500 to-cyan-500',
  'space-technology': 'from-violet-500 to-purple-500',
  'artificial-intelligence': 'from-primary-500 to-accent-500',
  'quantum-physics': 'from-rose-500 to-orange-500',
  'nature': 'from-green-500 to-emerald-500',
};

const categoryIcons: Record<string, string> = {
  'computer-science': '💻',
  'space-technology': '🚀',
  'artificial-intelligence': '🤖',
  'quantum-physics': '⚛️',
  'nature': '🌿',
};

const gradientClass = categoryColors[category] || 'from-primary-500 to-accent-500';
const icon = categoryIcons[category] || '📝';

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class:list={[
  'group relative rounded-2xl overflow-hidden transition-all duration-300',
  'border border-dark-500/50 hover:border-dark-400/50',
  'bg-dark-700/50 hover:bg-dark-700/80',
  'hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-500/5',
  featured ? 'md:col-span-2 md:row-span-2' : '',
]}>
  <a href={`/tech-blog/blog/${slug}/`} class="block h-full">
    <!-- Gradient top bar -->
    <div class={`h-1 bg-gradient-to-r ${gradientClass}`}></div>

    <div class:list={['p-6', featured ? 'md:p-8' : '']}>
      <!-- Category badge -->
      <div class="flex items-center gap-2 mb-3">
        <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-gradient-to-r ${gradientClass} bg-opacity-10 text-white/90`}>
          <span>{icon}</span>
          {category.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
        </span>
        <time class="text-dark-300 text-xs">{formattedDate}</time>
      </div>

      <!-- Title -->
      <h3 class:list={[
        'font-display font-semibold text-white group-hover:text-primary-300 transition-colors mb-2',
        featured ? 'text-2xl md:text-3xl' : 'text-lg',
      ]}>
        {title}
      </h3>

      <!-- Description -->
      <p class:list={[
        'text-dark-200 leading-relaxed',
        featured ? 'text-base' : 'text-sm line-clamp-3',
      ]}>
        {description}
      </p>

      <!-- Read more -->
      <div class="mt-4 flex items-center gap-1 text-primary-400 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
        Read more
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </a>
</article>
