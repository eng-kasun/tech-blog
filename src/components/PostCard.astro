---
interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  slug: string;
  image?: string;
  featured?: boolean;
}

const { title, description, date, category, slug, image, featured = false } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class:list={[
  'group relative rounded-xl overflow-hidden transition-all duration-300',
  'border border-dark-500/30 hover:border-primary-500/25',
  'bg-gradient-to-b from-dark-700/50 to-dark-800/30',
  'hover:shadow-xl hover:shadow-primary-900/20',
  featured ? 'md:col-span-2 md:row-span-2' : '',
]}>
  <a href={`/tech-blog/blog/${slug}/`} class="block h-full">
    <!-- Image -->
    {image ? (
      <div class="relative overflow-hidden">
        <img
          src={image}
          alt={title}
          class:list={[
            'w-full object-cover transition-transform duration-500 group-hover:scale-105',
            featured ? 'h-48 md:h-64' : 'h-44',
          ]}
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-dark-800 via-dark-800/40 to-transparent"></div>
        <!-- Category badge on image -->
        <div class="absolute bottom-3 left-4">
          <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-dark-900/80 backdrop-blur-sm text-[10px] font-semibold tracking-widest uppercase text-primary-300 border border-dark-500/30">
            {category.replace(/-/g, ' ')}
          </span>
        </div>
      </div>
    ) : (
      <div class="h-1.5 bg-gradient-to-r from-primary-500/60 via-primary-400/40 to-accent-500/60"></div>
    )}

    <div class:list={['p-6', featured ? 'md:p-8' : '']}>
      <!-- Date (category shown on image overlay or here if no image) -->
      <div class="flex items-center gap-3 mb-3">
        {!image && (
          <span class="text-[10px] font-semibold tracking-widest uppercase text-primary-300">
            {category.replace(/-/g, ' ')}
          </span>
        )}
        {!image && <span class="text-dark-500">·</span>}
        <time class="text-dark-300 text-xs">{formattedDate}</time>
      </div>

      <!-- Title -->
      <h3 class:list={[
        'font-display font-bold text-dark-50 group-hover:text-primary-300 transition-colors mb-2 leading-snug',
        featured ? 'text-2xl md:text-3xl' : 'text-lg',
      ]}>
        {title}
      </h3>

      <!-- Description -->
      <p class:list={[
        'text-dark-200 leading-relaxed',
        featured ? 'text-base' : 'text-sm line-clamp-3',
      ]}>
        {description}
      </p>

      <!-- Read more -->
      <div class="mt-5 flex items-center gap-1.5 text-primary-300 text-sm font-medium">
        <span class="group-hover:underline underline-offset-4">Read article</span>
        <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
      </div>
    </div>
  </a>
</article>
