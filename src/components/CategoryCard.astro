---
interface Props {
  name: string;
  slug: string;
  count: number;
  icon: string;
  gradient: string;
}

const { name, slug, count, icon, gradient } = Astro.props;
---

<a
  href={`/tech-blog/categories/${slug}/`}
  class="group relative rounded-2xl overflow-hidden border border-dark-500/50 hover:border-dark-400/50 bg-dark-700/50 hover:bg-dark-700/80 transition-all duration-300 hover:-translate-y-1 p-6 flex flex-col items-center text-center"
>
  <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${gradient} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform text-3xl`}>
    {icon}
  </div>
  <h3 class="font-display font-semibold text-white text-lg mb-1 group-hover:text-primary-300 transition-colors">{name}</h3>
  <p class="text-dark-300 text-sm">{count} {count === 1 ? 'article' : 'articles'}</p>
</a>
