---
interface Props {
  name: string;
  slug: string;
  count: number;
  icon: string;
  gradient?: string;
}

const { name, slug, count, icon } = Astro.props;
---

<a
  href={`/tech-blog/categories/${slug}/`}
  class="group relative rounded-lg overflow-hidden border border-dark-500/40 hover:border-primary-500/30 bg-dark-700/30 hover:bg-dark-700/60 transition-all duration-300 p-6 flex flex-col items-center text-center"
>
  <span class="text-3xl mb-4 block group-hover:scale-110 transition-transform">{icon}</span>
  <h3 class="font-display font-semibold text-dark-50 text-lg mb-1 group-hover:text-primary-300 transition-colors">{name}</h3>
  <p class="text-dark-300 text-sm mb-3">{count} {count === 1 ? 'article' : 'articles'}</p>
  <span class="text-dark-400 text-xs tracking-widest">— ✦ —</span>
</a>
