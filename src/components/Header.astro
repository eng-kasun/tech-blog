---
const navItems = [
  { label: 'Home', href: '/tech-blog/' },
  { label: 'Blog', href: '/tech-blog/blog/' },
  { label: 'Categories', href: '/tech-blog/categories/' },
  { label: 'About', href: '/tech-blog/about/' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-dark-900/95 backdrop-blur-md border-b border-dark-500/30">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/tech-blog/" class="flex items-center gap-2.5 group">
      <img src="/tech-blog/favicon.svg" alt="" class="w-8 h-8 rounded-lg" aria-hidden="true" />
      <span class="font-display font-bold text-lg text-dark-50 group-hover:text-primary-300 transition-colors">
        TechVerse
      </span>
    </a>

    <div class="hidden md:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
            currentPath === item.href || (item.href !== '/tech-blog/' && currentPath.startsWith(item.href))
              ? 'text-primary-300 bg-primary-500/10'
              : 'text-dark-200 hover:text-dark-50 hover:bg-dark-600/40',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-lg text-dark-200 hover:text-dark-50 hover:bg-dark-600/40 transition-colors"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-dark-500/40 bg-dark-800/95 backdrop-blur-sm">
    <div class="px-4 py-3 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block px-4 py-2.5 rounded-lg text-sm font-medium transition-all',
            currentPath === item.href
              ? 'text-primary-300 bg-primary-500/10'
              : 'text-dark-200 hover:text-dark-50 hover:bg-dark-600/40',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
