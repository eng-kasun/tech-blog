---
const navItems = [
  { label: 'Front Page', href: '/tech-blog/' },
  { label: 'All Articles', href: '/tech-blog/blog/' },
  { label: 'Sections', href: '/tech-blog/categories/' },
  { label: 'About', href: '/tech-blog/about/' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-dark-800 border-b-2 border-dark-300">
  <!-- Top info bar -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-2 flex items-center justify-between text-[11px] text-dark-50 uppercase tracking-widest font-sans border-b border-dark-400">
    <span id="header-clock"></span>
    <span>AI-Powered Daily</span>
    <span>Est. 2025</span>
  </div>

  <!-- Masthead -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 text-center">
    <div class="rule-double mb-4"></div>
    <a href="/tech-blog/" class="block">
      <h1 class="font-blackletter text-5xl sm:text-6xl md:text-7xl text-paper-100 tracking-tight leading-none">
        The TechVerse
      </h1>
      <p class="font-headline italic text-paper-500 text-sm sm:text-base mt-2 tracking-wide">
        Science &amp; Technology Intelligence — Composed by Artificial Minds
      </p>
    </a>
    <div class="rule-double mt-4"></div>
  </div>

  <!-- Navigation bar -->
  <nav class="bg-dark-900 text-paper-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-center">
      <div class="hidden md:flex items-center divide-x divide-dark-400">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-5 py-2.5 text-xs font-sans font-semibold uppercase tracking-widest transition-colors',
              currentPath === item.href || (item.href !== '/tech-blog/' && currentPath.startsWith(item.href))
                ? 'bg-dark-600 text-paper-100'
                : 'text-paper-400 hover:text-paper-100 hover:bg-dark-600',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden py-2.5 text-paper-400 hover:text-paper-100 transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-dark-400">
      <div class="max-w-5xl mx-auto px-4 py-2 space-y-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'block px-4 py-2 text-xs font-sans font-semibold uppercase tracking-widest transition-colors',
              currentPath === item.href
                ? 'text-paper-100 bg-dark-600'
                : 'text-paper-400 hover:text-paper-100',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  const clockEl = document.getElementById('header-clock');
  function updateClock() {
    const now = new Date();
    const date = now.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    const time = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    if (clockEl) clockEl.textContent = `${date} · ${time}`;
  }
  updateClock();
  setInterval(updateClock, 1000);
</script>
