---
const year = new Date().getFullYear();
---

<footer class="border-t border-dark-500/40 bg-dark-800/50 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <span class="text-primary-300 text-2xl leading-none" aria-hidden="true">☙</span>
          <span class="font-display font-semibold text-lg text-dark-50">TechVerse</span>
        </div>
        <p class="text-dark-200 text-sm leading-relaxed">
          Exploring the frontiers of technology, science, and the natural world. AI-powered content for curious minds.
        </p>
      </div>

      <div>
        <h3 class="font-display font-semibold text-dark-50 mb-4">Categories</h3>
        <ul class="space-y-2">
          {['Computer Science', 'Space Technology', 'Artificial Intelligence', 'Quantum Physics', 'Nature'].map(cat => (
            <li>
              <a href={`/tech-blog/categories/${cat.toLowerCase().replace(/\s+/g, '-')}/`} class="text-dark-200 hover:text-primary-300 text-sm transition-colors">
                {cat}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-display font-semibold text-dark-50 mb-4">Connect</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://github.com" class="text-dark-200 hover:text-primary-300 text-sm transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-dark-500/30 text-center">
      <div class="ornament mb-4">✦</div>
      <p class="text-dark-300 text-sm">
        &copy; {year} TechVerse. Powered by AI &middot; Built with Astro &middot; Hosted on GitHub Pages
      </p>
    </div>
  </div>
</footer>
