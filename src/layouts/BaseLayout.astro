---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Exploring the frontiers of Computer Science, Space, AI, Quantum Physics & Nature', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:url" content={canonicalURL} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/tech-blog/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+" crossorigin="anonymous" />
    <title>{title} | TechVerse</title>
  </head>
  <body class="bg-dark-900 text-dark-50 min-h-screen flex flex-col antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  ::selection {
    background-color: rgba(196, 154, 108, 0.3);
    color: #fff;
  }

  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #1a1814;
  }
  ::-webkit-scrollbar-thumb {
    background: #4a4238;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #6d6354;
  }

  /* Ornamental divider */
  .ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #6d6354;
    font-size: 0.875rem;
    letter-spacing: 0.15em;
  }
  .ornament::before,
  .ornament::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, #4a4238, transparent);
  }

  .prose {
    @apply text-dark-50 leading-relaxed;
    font-size: 1.0625rem;
    line-height: 1.85;
  }
  .prose h1, .prose h2, .prose h3, .prose h4 {
    @apply font-display text-dark-50 font-semibold mt-10 mb-5;
    letter-spacing: -0.01em;
  }
  .prose h1 { @apply text-3xl; }
  .prose h2 { @apply text-2xl; border-bottom: 1px solid #3d3529; padding-bottom: 0.5rem; }
  .prose h3 { @apply text-xl; }
  .prose p { @apply mb-5 text-dark-50; }
  .prose a { @apply text-primary-300 hover:text-primary-200 underline underline-offset-4 decoration-primary-500/40 hover:decoration-primary-300/60 transition-colors; }
  .prose code { @apply bg-dark-600 px-1.5 py-0.5 rounded text-sm font-mono text-primary-200; }
  .prose pre { @apply bg-dark-700 p-4 rounded-lg overflow-x-auto mb-6 border border-dark-500; }
  .prose pre code { @apply bg-transparent p-0; }
  .prose ul, .prose ol { @apply mb-5 pl-6; }
  .prose ul { @apply list-disc; }
  .prose ol { @apply list-decimal; }
  .prose li { @apply mb-2; }
  .prose blockquote { @apply border-l-4 border-primary-400 pl-5 italic text-dark-100 my-6; font-family: 'Playfair Display', Georgia, serif; }
  .prose img { @apply rounded-lg my-6; }
  .prose strong { @apply text-dark-50 font-semibold; }
  .prose hr { border: none; text-align: center; margin: 2.5rem 0; color: #6d6354; letter-spacing: 0.3em; }
  .prose hr::after { content: '✦  ✦  ✦'; }
  .prose table { @apply w-full my-6 text-sm; border-collapse: separate; border-spacing: 0; }
  .prose thead th { @apply px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-dark-100 bg-dark-700 border-b border-dark-500; }
  .prose thead th:first-child { @apply rounded-tl-lg; }
  .prose thead th:last-child { @apply rounded-tr-lg; }
  .prose tbody td { @apply px-4 py-3 border-b border-dark-500/40; }
  .prose tbody tr { @apply transition-colors duration-150; }
  .prose tbody tr:hover { @apply bg-dark-700/50; }
  .prose tbody tr:last-child td { @apply border-b-0; }
  .prose tbody tr:last-child td:first-child { @apply rounded-bl-lg; }
  .prose tbody tr:last-child td:last-child { @apply rounded-br-lg; }
  .complexity-badge { @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold font-mono; }
  .complexity-green { @apply bg-emerald-500/15 text-emerald-400 ring-1 ring-emerald-500/30; }
  .complexity-lime { @apply bg-lime-500/15 text-lime-400 ring-1 ring-lime-500/30; }
  .complexity-yellow { @apply bg-yellow-500/15 text-yellow-400 ring-1 ring-yellow-500/30; }
  .complexity-amber { @apply bg-amber-500/15 text-amber-400 ring-1 ring-amber-500/30; }
  .complexity-orange { @apply bg-orange-500/15 text-orange-400 ring-1 ring-orange-500/30; }
  .complexity-red { @apply bg-red-500/15 text-red-400 ring-1 ring-red-500/30; }
  .complexity-rose { @apply bg-rose-500/15 text-rose-400 ring-1 ring-rose-500/30; }
  .stable-yes { @apply text-emerald-400; }
  .stable-no { @apply text-red-400; }
</style>
