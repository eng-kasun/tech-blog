---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Exploring the frontiers of Computer Science, Space, AI, Quantum Physics & Nature', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:url" content={canonicalURL} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/tech-blog/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+" crossorigin="anonymous" />
    <title>{title} | TechVerse</title>
  </head>
  <body class="bg-dark-700 text-paper-200 font-body min-h-screen flex flex-col antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  ::selection {
    background-color: rgba(196, 68, 60, 0.3);
    color: #f5edd9;
  }

  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #100e0b; }
  ::-webkit-scrollbar-thumb { background: #3a3228; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #4a4238; }

  /* Newspaper rule lines — light on dark */
  .rule-thick { border-top: 3px solid #9a9080; }
  .rule-thin { border-top: 1px solid #6e6558; }
  .rule-double { border-top: 3px double #9a9080; }
  .rule-dotted { border-top: 1px dotted #6e6558; }

  /* Column divider */
  .col-rule {
    border-right: 1px solid #4a4238;
  }

  .prose {
    @apply text-paper-200 leading-relaxed font-body;
    font-size: 1.0625rem;
    line-height: 1.85;
  }
  .prose h1, .prose h2, .prose h3, .prose h4 {
    @apply font-headline text-paper-100 font-bold mt-10 mb-5;
    letter-spacing: -0.02em;
  }
  .prose h1 { @apply text-3xl; }
  .prose h2 { @apply text-2xl; border-bottom: 2px solid #6e6558; padding-bottom: 0.5rem; }
  .prose h3 { @apply text-xl; }
  .prose p { @apply mb-5 text-paper-200; }
  .prose a { @apply text-accent-light hover:text-accent underline underline-offset-4 decoration-accent/40 hover:decoration-accent/70 transition-colors; }
  .prose code { @apply bg-dark-500 px-1.5 py-0.5 rounded text-sm font-mono text-paper-300; }
  .prose pre { @apply bg-dark-900 text-paper-200 p-4 rounded overflow-x-auto mb-6 border border-dark-400; }
  .prose pre code { @apply bg-transparent p-0 text-paper-200; }
  .prose ul, .prose ol { @apply mb-5 pl-6; }
  .prose ul { @apply list-disc; }
  .prose ol { @apply list-decimal; }
  .prose li { @apply mb-2; }
  .prose blockquote { @apply border-l-4 border-paper-500 pl-5 italic text-paper-400 my-6 font-headline; }
  .prose img { @apply my-6; }
  .prose strong { @apply text-paper-100 font-bold; }
  .prose hr { border: none; text-align: center; margin: 2.5rem 0; }
  .prose hr::after { content: '— ✦ —'; color: #6e6558; letter-spacing: 0.3em; font-size: 0.875rem; }
  .prose table { @apply w-full my-6 text-sm; border-collapse: collapse; }
  .prose thead th { @apply px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-paper-100 bg-dark-500 border-b-2 border-dark-200; }
  .prose tbody td { @apply px-4 py-3 border-b border-dark-400; }
  .prose tbody tr:hover { @apply bg-dark-600; }
  .complexity-badge { @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold font-mono; }
  .complexity-green { @apply bg-emerald-100 text-emerald-800 ring-1 ring-emerald-300; }
  .complexity-lime { @apply bg-lime-100 text-lime-800 ring-1 ring-lime-300; }
  .complexity-yellow { @apply bg-yellow-100 text-yellow-800 ring-1 ring-yellow-300; }
  .complexity-amber { @apply bg-amber-100 text-amber-800 ring-1 ring-amber-300; }
  .complexity-orange { @apply bg-orange-100 text-orange-800 ring-1 ring-orange-300; }
  .complexity-red { @apply bg-red-100 text-red-800 ring-1 ring-red-300; }
  .complexity-rose { @apply bg-rose-100 text-rose-800 ring-1 ring-rose-300; }
  .stable-yes { @apply text-emerald-700; }
  .stable-no { @apply text-red-700; }
</style>
