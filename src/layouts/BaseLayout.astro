---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Exploring the frontiers of Computer Science, Space, AI, Quantum Physics & Nature', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:url" content={canonicalURL} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/tech-blog/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5RLHO8BqSUDsOlnKPdReu05IbKBrpyjE4DGUS2koXHUqGVFJ/jN" crossorigin="anonymous" />
    <title>{title} | TechVerse</title>
  </head>
  <body class="bg-dark-900 text-dark-50 min-h-screen flex flex-col antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  ::selection {
    background-color: rgba(92, 124, 250, 0.3);
    color: #fff;
  }

  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #141517;
  }
  ::-webkit-scrollbar-thumb {
    background: #373a40;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #5c5f66;
  }

  .prose {
    @apply text-dark-100 leading-relaxed;
  }
  .prose h1, .prose h2, .prose h3, .prose h4 {
    @apply font-display text-white font-semibold mt-8 mb-4;
  }
  .prose h1 { @apply text-3xl; }
  .prose h2 { @apply text-2xl; }
  .prose h3 { @apply text-xl; }
  .prose p { @apply mb-4 text-dark-100; }
  .prose a { @apply text-primary-400 hover:text-primary-300 underline underline-offset-2; }
  .prose code { @apply bg-dark-600 px-1.5 py-0.5 rounded text-sm font-mono text-accent-300; }
  .prose pre { @apply bg-dark-700 p-4 rounded-lg overflow-x-auto mb-6 border border-dark-500; }
  .prose pre code { @apply bg-transparent p-0; }
  .prose ul, .prose ol { @apply mb-4 pl-6; }
  .prose ul { @apply list-disc; }
  .prose ol { @apply list-decimal; }
  .prose li { @apply mb-2; }
  .prose blockquote { @apply border-l-4 border-primary-500 pl-4 italic text-dark-200 my-4; }
  .prose img { @apply rounded-lg my-6; }
  .prose strong { @apply text-white font-semibold; }
</style>
